{
  "name": "job-globe.com",
  "version": "0.1.0",
  "private": true,
  "description": "Jarvis Job Globe monorepo foundation.",
  "workspaces": ["apps/web"],
  "scripts": {
    "dev": "docker compose -f infra/docker/docker-compose.dev.yml up --build",
    "dev:web": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "lint": "npm --workspace apps/web run lint",
    "typecheck": "npm --workspace apps/web run typecheck",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,yml,yaml}\"",
    "migration:check": "python packages/database/scripts/validate_migrations.py packages/database/migrations"
  },
  "devDependencies": {"prettier": "^3.3.3"},
  "engines": {"node": ">=20.0.0", "npm": ">=10.0.0"}
}
