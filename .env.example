# Job Globe environment template
#
# Local setup:
#   Copy this file to .env and fill in real values where marked.
#   The root .env file is ignored by Git and is used by Docker Compose.
#
# Staging/production:
#   Put these values in Vercel, Supabase, GitHub Actions, or the selected
#   managed secret store. Do not commit real secrets.

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
# Public URL format: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

# Auth/session
AUTH_PROVIDER=supabase
AUTH_SECRET=replace-with-random-secret
SESSION_COOKIE_NAME=job_globe_session
SESSION_TTL_SECONDS=3600

# Local database defaults match infra/docker/docker-compose.dev.yml.
POSTGRES_USER=job_globe
POSTGRES_PASSWORD=job_globe
POSTGRES_DB=job_globe
DATABASE_URL=postgresql://job_globe:job_globe@localhost:5432/job_globe

# Local cache
REDIS_URL=redis://localhost:6379/0
REDIS_STREAM_DISCOVERY=job-globe.discovery
REDIS_STREAM_ALERTS=job-globe.alerts

# AI/embeddings
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Supabase Storage for resumes
# apps/web currently uses a private bucket named "resumes".
RESUME_RAW_RETENTION_DAYS=30

# Email/alerts
TRANSACTIONAL_EMAIL_API_KEY=
ALERT_DAILY_MAX_PER_USER=5

# Resend email (for alert delivery)
RESEND_API_KEY=re_replace_with_resend_api_key
ALERT_FROM_EMAIL=alerts@job-globe.com
# ALERT_DAILY_MAX_PER_USER is already set above; override here if needed.

# Webhook secrets
GREENHOUSE_WEBHOOK_SECRET=replace-with-greenhouse-webhook-secret
LEVER_WEBHOOK_SECRET=replace-with-lever-webhook-secret

# Redis consumer groups
REDIS_CONSUMER_GROUP=job-globe-workers
REDIS_CONSUMER_NAME=worker-0
REDIS_MAX_RETRIES=3

# Railway deployment
RAILWAY_PROJECT_ID=replace-with-railway-project-id

# Quick-prep (AI interview prep feature)
QUICK_PREP_MODEL=gpt-4o-mini
QUICK_PREP_CACHE_TTL_HOURS=24

# Audit retention
AUDIT_CLEANUP_INTERVAL_HOURS=24
